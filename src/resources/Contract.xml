        <join name="cmContractParty" joinKey="contractId-contractId" joinType="oneToMany" isAggregation="true" class="avicit.cm.domain.contract.entity.CmContractParty"></join>
<!--        <join name="cmContractGoods" joinKey="id-contractId" joinType="oneToMany" isAggregation="true" class="avicit.cm.domain.contract.entity.CmContractGoods"></join>-->
<!--        <join name="cmContractRef" joinKey="contractId-contractId" joinType="oneToMany" isAggregation="true" class="avicit.cm.domain.contract.entity.CmContractRef"></join>-->
        <multiJoin name="cmContractGoods" multiJoinKey="contractId-contractId" multiJoinType="oneToMany"
                   paramType="assign" params="{entity:['revsion-revsion']}" isAggregation="true"
                returnType="vo" class="avicit.cm.domain.contract.entity.CmContractGoods"/>
        <multiJoin name="cmContractRef" multiJoinKey="contractId-contractId" multiJoinType="oneToMany"
                   paramType="assign" params="{entity:['revsion-revsion']}" isAggregation="true"
                   returnType="vo" class="avicit.cm.domain.contract.entity.CmContractRef"/>
        <join name="contract" joinKey="contractId-id" joinType="manyToOne" isAggregation="true" class="avicit.cm.domain.contract.entity.Contract"></join>
