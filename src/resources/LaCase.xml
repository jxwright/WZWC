        <property name="objectAmountFc" column="OBJECT_AMOUNT_FC"/>
        <extend isAggregation="true" class="ssp.lib.docEntity.entity.BizDoc"/>
        <join name="laCaseData" joinKey="id-id" joinType="manyToOne" isAggregation="true" class="avicit.la.domain.laCase.entity.LaCaseData"></join>
        <lookup name="laCaseStage" lookupKey="id-caseId" lookupType="manyToOne"
                paramType="none"
                returnType="vo"
                bean="LaCase" method="getCaseHandleStage"/>
        <join name="laCasePartyList" joinKey="id-caseId" joinType="oneToMany" isAggregation="false" class="avicit.la.domain.laCase.entity.LaCaseParty"></join>
    </vo>

    <vo class="avicit.la.domain.laCase.entity.LaCaseSolution" tableName="LA_CASE_SOLUTION">
        <property name="id" column="ID" isPrimaryKey="true"/>
        <property name="caseId" column="CASE_ID"/>
        <extend isAggregation="true" class="ssp.lib.docEntity.entity.FlowDoc"/>
        <join name="laCase" joinKey="caseId-id" joinType="manyToOne" isAggregation="true" class="avicit.la.domain.laCase.entity.LaCase"></join>
        <join name="laLegalDocs" joinKey="id-docId" joinType="oneToMany" isAggregation="false" class="avicit.la.domain.laCase.entity.LaLegalDocs"></join>
    </vo>

    <vo class="avicit.la.domain.laCase.entity.LaCaseType" tableName="LA_CASE_TYPE">
