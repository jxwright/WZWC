<?xml version="1.0" encoding="UTF-8"?>
<vobjs>
    <vo class="avicit.la.domain.laCase.entity.LaCaseData" tableName="LA_CASE_DATA">
        <property name="id" column="ID" isPrimaryKey="true"/>
        <property name="caseName" column="CASE_NAME"/>
        <property name="caseOrg" column="CASE_ORG"/>
        <lookup name="caseOrgName" lookupKey="caseOrg-deptId" lookupType="manyToOne"
                paramType="none"
                returnType="value" returnKey="deptName"
                bean="sysDeptDomainServiceImpl" method="getDeptNameById"/>
        <property name="caseOrgManager" column="CASE_ORG_MANAGER"/>
        <lookup name="caseOrgManagerName" lookupKey="caseOrgManager-userId" lookupType="manyToOne"
                paramType="none"
                returnType="value" returnKey="userName"
                bean="sysUserDomainServiceImpl" method="getUserNameById"/>
        <property name="caseOrgAgent" column="CASE_ORG_AGENT"/>
        <lookup name="caseOrgAgentName" lookupKey="caseOrgAgent-userId" lookupType="manyToOne"
                paramType="none"
                returnType="value" returnKey="userName"
                bean="sysUserDomainServiceImpl" method="getUserNameById"/>
        <property name="caseOrgTel" column="CASE_ORG_TEL"/>
        <property name="currencyCode" column="CURRENCY_CODE"/>
        <property name="exchangeRate" column="EXCHANGE_RATE"/>
        <property name="caseAmount" column="CASE_AMOUNT"/>
        <property name="caseAmountFc" column="CASE_AMOUNT_FC"/>
        <property name="isRelateContract" column="IS_RELATE_CONTRACT"/>
        <property name="isRelateCase" column="IS_RELATE_CASE"/>
        <property name="caId" column="CA_ID"/>
        <lookup name="caName" lookupKey="caId-id" lookupType="manyToOne"
                paramType="none"
                returnType="value" returnKey="name"
                bean="LaCase" method="getCaNameById"/>
        <property name="isCaFiling" column="IS_CA_FILING"/>
        <property name="caCaseno" column="CA_CASENO"/>
        <property name="caFilingDate" column="CA_FILING_DATE"/>
        <property name="caHearTime" column="CA_HEAR_TIME"/>
        <property name="caseDetail" column="CASE_DETAIL"/>
        <property name="claims" column="CLAIMS"/>
        <property name="caseCatalog" column="CASE_CATALOG"/>
        <lookup name="caseCatalogName" lookupKey="caseCatalog-refId" lookupType="manyToOne"
                paramType="none"
                returnType="value" returnKey="refName"
                bean="sspRefCodeService" method="getRefNameById"/>
        <extend isAggregation="true" class="avicit.la.domain.laCase.entity.LaCaseFilingReq"/>
        <lookup name="relateContract" lookupKey="id-caseId" lookupType="oneToMany"
                paramType="none"
                returnType="vo"
                bean="LaCase" method="getRelateContractById"/>
        <lookup name="relateCase" lookupKey="id-caseId" lookupType="oneToMany"
                paramType="none"
                returnType="vo"
                bean="LaCase" method="getRelateCaseById"/>
        <join name="laCasePartyList" joinKey="id-caseId" joinType="oneToMany" isAggregation="true" class="avicit.la.domain.laCase.entity.LaCaseParty"></join>
        <join name="laLegalDocs" joinKey="id-docId" joinType="oneToMany" isAggregation="false" class="avicit.la.domain.laCase.entity.LaLegalDocs"></join>
    </vo>

    <vo class="avicit.la.domain.laCase.entity.LaCaseFilingReq" tableName="LA_CASE_FILING_REQ">
        <property name="id" column="ID" isPrimaryKey="true"/>
        <property name="caseHandleWay" column="CASE_HANDLE_WAY"/>
        <property name="caseType" column="CASE_TYPE"/>
        <property name="isFiling" column="IS_FILING"/>
        <extend isAggregation="true" class="ssp.lib.docEntity.entity.FlowDoc"/>
    </vo>

    <vo class="avicit.la.domain.laCase.entity.LaCase" tableName="LA_CASE">
        <property name="id" column="ID" isPrimaryKey="true"/>
        <property name="caseType" column="CASE_TYPE"/>
        <property name="caseLevel" column="CASE_LEVEL"/>
        <property name="caseHandleWay" column="CASE_HANDLE_WAY"/>
        <property name="caseAgent" column="CASE_AGENT"/>
        <property name="isExternal" column="IS_EXTERNAL"/>
        <property name="inProcess" column="IN_PROCESS"/>
        <property name="handleState" column="HANDLE_STATE"/>
        <property name="handleStage" column="HANDLE_STAGE"/>
        <property name="execState" column="EXEC_STATE"/>
        <property name="filingDate" column="FILING_DATE"/>
        <property name="closeType" column="CLOSE_TYPE"/>
        <property name="closeDate" column="CLOSE_DATE"/>
        <property name="execDate" column="EXEC_DATE"/>
        <property name="handleBudget" column="HANDLE_BUDGET"/>
        <property name="handleTotal" column="HANDLE_TOTAL"/>
        <property name="decisionAmount" column="DECISION_AMOUNT"/>
        <property name="decisionAmountFc" column="DECISION_AMOUNT_FC"/>
        <property name="execAmount" column="EXEC_AMOUNT"/>
        <property name="execAmountFc" column="EXEC_AMOUNT_FC"/>
        <property name="decidsionDetail" column="DECIDSION_DETAIL"/>
        <property name="execDetail" column="EXEC_DETAIL"/>
        <property name="caseBrief" column="CASE_BRIEF"/>
        <property name="allowExec" column="ALLOW_EXEC"/>
